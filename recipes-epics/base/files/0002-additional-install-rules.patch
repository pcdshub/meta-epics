diff --git a/configure/RULES.Alarm b/configure/RULES.Alarm
new file mode 100644
index 000000000..cefe9460b
--- /dev/null
+++ b/configure/RULES.Alarm
@@ -0,0 +1,97 @@
+# Where to install configuration files for ALH (Alarm Handler)
+
+vpath %.alhConfig $(USR_VPATH) $(GENERIC_SRC_DIRS) $(dir $(ALH))
+vpath %.alhsubstitutions $(USR_VPATH) $(GENERIC_SRC_DIRS) $(COMMON_DIR)
+
+INSTALL_ALH = $(INSTALL_LOCATION)/alh
+
+##################################################### Restore Flags
+
+INSTALL_ALHFLAGS = -I $(INSTALL_ALH)
+RELEASE_ALHFLAGS = $(patsubst %/dbd,%/restore, $(RELEASE_DBDFLAGS))
+ALHFLAGS  = $($*_ALHFLAGS) $(USR_ALHFLAGS) -I. $(GENERIC_SRC_INCLUDES) $(INSTALL_ALHFLAGS) $(RELEASE_ALHFLAGS)
+ALHFLAGS += -I$(COMMON_DIR)
+
+#####################################################  Targets
+
+INSTALL_ALHS += $(addprefix $(INSTALL_ALH)/,$(notdir $(ALHS)))
+
+COMMON_ALHS += $(filter $(COMMON_DIR)/%, $(foreach file, $(ALHS), \
+    $(firstword  $(SOURCE_ALHS) $(COMMON_DIR)/$(file) ) ) )
+SOURCE_ALHS = $(wildcard $(file) $(SOURCE_ALHS_bbb) )
+SOURCE_ALHS_bbb = $(foreach dir, $(GENERIC_SRC_DIRS), $(SOURCE_ALHS_aaa)  )
+SOURCE_ALHS_aaa = $(addsuffix /$(file), $(dir) )
+
+COMMONS = $(COMMON_DIR)/*.alhConfig \
+          $(COMMON_DIR)/*.alhsubstitutions
+
+##################################################### 
+
+ifndef T_A
+
+COMMON_DIR = .
+INSTALL_ALHS =
+COMMON_ALHS = .
+COMMONS = $(ALHS)
+
+-include $(TOP)/configure/O.$(EPICS_HOST_ARCH)/CONFIG_APP_INCLUDE
+
+all:    install
+
+install: buildInstall
+
+buildInstall : build
+
+rebuild: clean install
+
+.PHONY: all inc build install clean rebuild buildInstall
+
+endif # T_A defined
+
+ifneq (,$(strip $(ALH_INSTALLS)))
+buildInstall : restoreInstalls
+endif
+
+.PHONY: restoreInstalls
+
+build : $(COMMON_ALHS) \
+	$(INSTALL_ALHS)
+
+clean: 
+	@$(RM) $(COMMONS)
+
+##################################################### Substitution files
+
+$(INSTALL_ALH)/%.alhsubstitutions: %.alhsubstitutions
+	@echo "Installing alhsubstitutions file $@"
+	@$(INSTALL) -d -m 644 $< $(@D)
+
+.PRECIOUS: $(COMMON_DIR)/%.alhsubstitutions
+
+##################################################### alhConfig files
+
+$(COMMON_DIR)/%.alhConfig: %.alhsubstitutions
+	@echo "Inflating alhConfig from $< using local rule"
+	@$(RM) $@
+	@echo "$(MSI3_15) -S$< > $(@F) </dev/null"
+	@$(MSI3_15) -I.. $(ALHFLAGS) -S$< </dev/null > $@
+
+$(INSTALL_ALH)/%.alhConfig: $(COMMON_DIR)/%.alhConfig
+	@echo "Installing alhConfig file $@"
+	@$(INSTALL) -d -m 644 $< $(@D)
+
+$(INSTALL_ALH)/%: %
+	@echo "Installing restore file $@"
+	@$(INSTALL) -d -m 644 $< $(@D)
+
+$(INSTALL_ALH)/%: ../%
+	@echo "Installing restore file $@"
+	@$(INSTALL) -d -m 644 $< $(@D)
+
+restoreInstalls:  $(ALH_INSTALLS)
+	@echo "Installing $(^F)"
+	@$(INSTALL) -d -m 555 $^ $(INSTALL_ALH)
+
+.PRECIOUS: $(COMMON_ALHS)
+
+##################################################### END OF FILE
diff --git a/configure/RULES.Restore b/configure/RULES.Restore
new file mode 100644
index 000000000..75350061b
--- /dev/null
+++ b/configure/RULES.Restore
@@ -0,0 +1,83 @@
+# Where to install configuration files for ChannelWatcher
+# RULES for building and installing ChannelWatcher *.cwConfig files
+
+# Display how this makefile was called
+#$(info RULES.Restore: '$(MAKECMDGOALS)')
+
+####################################################
+# Where to find ChannelWatcher files
+vpath %.cw              $(USR_VPATH) $(GENERIC_SRC_DIRS) $(dir $(RESTORE))
+vpath %.cwConfig        $(USR_VPATH) $(GENERIC_SRC_DIRS) $(dir $(RESTORE))
+vpath %.tpl-cw          $(USR_VPATH) $(GENERIC_SRC_DIRS) $(dir $(RESTORE))
+vpath %.sub-cw          $(USR_VPATH) $(GENERIC_SRC_DIRS) $(dir $(RESTORE))
+vpath %.cwsubstitutions $(USR_VPATH) $(GENERIC_SRC_DIRS) $(dir $(RESTORE))
+
+# Install ChannelWatcher files here
+INSTALL_RESTORE = $(INSTALL_LOCATION)/restore
+
+####################################################
+# channelWatcher include Flags (msi -I path)
+define  RESTORE_DIRS_template
+  RELEASE_RESTORE_DIRS += $$(wildcard $$(strip $$($(1)))/restore)
+endef
+$(foreach top, $(RELEASE_TOPS), \
+	$(eval $(call RESTORE_DIRS_template,$(top)) ))
+RESTORE_SEARCH_DIRS = . .. $(COMMON_DIR) $(SRC_DIRS) $(INSTALL_RESTORE) $(TOP)/archive $(RELEASE_RESTORE_DIRS)
+RESTORE_INCLUDES = $(addprefix -I, $(RESTORE_SEARCH_DIRS))
+RESTOREFLAGS  = $($*_RESTOREFLAGS) $(USR_RESTOREFLAGS) $(RESTORE_INCLUDES)
+
+####################################################
+# Generate COMMON_RESTORES list
+COMMON_RESTORES  += $(filter $(COMMON_DIR)/%, \
+	$(foreach file, $(RESTORE), \
+		$(firstword $(SOURCE_RESTORES) $(COMMON_DIR)/$(file) ) ) )
+SOURCE_RESTORES = $(wildcard $(file) $(SOURCE_RESTORES_bbb) )
+SOURCE_RESTORES_bbb = $(foreach dir, $(GENERIC_SRC_DIRS), $(SOURCE_RESTORES_aaa)  )
+SOURCE_RESTORES_aaa = $(addsuffix /$(file), $(dir) )
+
+# Generate INSTALL_RESTORES list
+INSTALL_RESTORES += $(addprefix $(INSTALL_RESTORE)/, $(notdir $(RESTORE)))
+
+####################################################
+# Generate RESTORE_DEPENDS_FILES list
+RESTORE_DEPENDS_FILES += $(addsuffix $(DEP), $(patsubst $(COMMON_DIR)/%,%,$(COMMON_RESTORES)))
+
+####################################################
+# Build targets
+
+install:        $(INSTALL_RESTORES)
+
+build:          $(COMMON_RESTORES)
+
+####################################################
+# Build and install Rules
+
+$(INSTALL_RESTORE)/%: %
+	@$(ECHO) "Installing cwConfig file $@"
+	@$(INSTALL) -d -m 644 $< $(@D)
+
+$(COMMON_DIR)/%.cwConfig: %.sub-cw
+	$(RM) $(notdir $@)$(DEP)
+	$(MKMF) -m $(notdir $@)$(DEP) $(RESTORE_INCLUDES) $@ $< 
+	@$(ECHO) "Inflating cwConfig from $<"
+	@$(RM) $@
+	$(MSI3_15) $(RESTOREFLAGS) -S$< > $@
+
+$(COMMON_DIR)/%.cwConfig: %.cwsubstitutions
+	$(RM) $(notdir $@)$(DEP)
+	$(MKMF) -m $(notdir $@)$(DEP) $(RESTORE_INCLUDES) $@ $< 
+	@$(ECHO) "Inflating cwConfig from $<"
+	@$(RM) $@
+	$(MSI3_15) $(RESTOREFLAGS) -S$< > $@
+
+$(INSTALL_RESTORE)/%.cwConfig: $(COMMON_DIR)/%.cwConfig
+	@$(ECHO) "Installing generated cwConfig file $@"
+	@$(INSTALL) -d -m 644 $< $(@D)
+
+#####################################################
+# Include ChannelWatcher config dependency files
+ifneq (,$(strip $(RESTORE_DEPENDS_FILES)))
+-include $(RESTORE_DEPENDS_FILES)
+endif
+
+##################################################### END OF FILE
